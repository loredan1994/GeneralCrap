// Manual targeted drill-down for Windows Security events when they land in Event.
// Use this only for the classic Event table path where EventLog == Security.
// If SecurityEvent exists and is populated, prefer the dedicated SecurityEvent path.

let Lookback = 3d;
let TopN = 50;
let TargetComputer = "";
let TargetSource = "";
let TargetEventID = int(-1);
Event
| where TimeGenerated >= ago(Lookback)
| where tolower(tostring(_IsBillable)) == "true"
| where EventLog =~ "Security"
| where isempty(TargetComputer) or Computer =~ TargetComputer
| where isempty(TargetSource) or Source =~ TargetSource
| where TargetEventID == -1 or EventID == TargetEventID
| summarize
    Rows = count(),
    GB = sum(_BilledSize) / 1e9,
    AvgKB = avg(_BilledSize) / 1024.0,
    DistinctUsers = dcountif(UserName, isnotempty(UserName)),
    SampleDescription = any(RenderedDescription),
    ExampleUser = any(UserName)
  by EventID, EventLevelName, Source, Computer
| top TopN by GB desc
| project
    EventID,
    EventLevelName,
    Source,
    Computer,
    ExampleUser,
    GB = round(GB, 3),
    Rows,
    AvgKB = round(AvgKB, 2),
    DistinctUsers,
    SampleDescription
